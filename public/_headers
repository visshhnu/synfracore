# Cache Next.js static assets forever (hashed filenames)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache fonts forever
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images for 24 hours
/images/*
  Cache-Control: public, max-age=86400

# Cache content markdown files for 1 hour (fast delivery, still updates daily)
/content/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Cache public assets (logos, icons, manifest) for 24 hours
/*.png
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.json
  Cache-Control: public, max-age=3600
/*.ico
  Cache-Control: public, max-age=86400

# Security headers for all HTML pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cache-Control: public, max-age=0, must-revalidate
